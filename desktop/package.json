{
  "name": "datamaster-desktop",
  "version": "0.6.0",
  "private": true,
  "description": "DataMaster personal business analysis desktop application",
  "main": "main.cjs",
  "scripts": {
    "prestart": "node prepare-electron.cjs",
    "start": "electron .",
    "build:mac": "electron-builder --mac dir",
    "dist:mac": "electron-builder --mac dmg",
    "dist:win": "electron-builder --win nsis --x64 --config electron-builder.win.json"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.datamaster.personal",
    "productName": "DataMaster",
    "asar": true,
    "files": [
      "main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/target/datamaster-demo-0.1.0.jar",
        "to": "backend/datamaster.jar"
      },
      {
        "from": "runtime",
        "to": "runtime"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.business",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dir",
          "arch": ["arm64"]
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
